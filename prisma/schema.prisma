model OrgPersonIssue {
  id          String    @id @default(cuid())
  orgId       String
  personId    String
  type        String // e.g. "MISSING_MANAGER"
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  resolvedAt  DateTime?

  // Phase 1: Issue resolution tracking for LoopBrain reasoning
  resolution     IssueResolution @default(PENDING)
  resolutionNote String? // Optional explanation for ACKNOWLEDGED/FALSE_POSITIVE
  resolvedById   String? // User who resolved the issue

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, personId, type])
  @@index([orgId, type, resolvedAt])
  @@index([orgId, resolution])
  @@map("org_person_issues")
}

// Phase 1: Issue resolution states for structural integrity tracking
enum IssueResolution {
  PENDING // Issue not yet addressed
  ACKNOWLEDGED // Issue is known and intentional
  FALSE_POSITIVE // Issue was incorrectly flagged
  RESOLVED // Issue has been fixed
}

// Hybrid issues storage: derive on-demand, store resolved by issueKey for reconciliation
model OrgIssueResolution {
  id             String    @id @default(cuid())
  workspaceId    String
  issueKey       String // PRIMARY IDENTIFIER: `${issueType}:${entityType}:${entityId}` (e.g., "OWNERSHIP_CONFLICT:TEAM:c123")
  issueType      String // e.g., "OWNERSHIP_CONFLICT", "UNOWNED_TEAM"
  entityType     String // "TEAM", "DEPARTMENT", "PERSON", "POSITION"
  entityId       String // ID of the entity with the issue
  resolvedBy     String // userId - User who marked this as resolved
  resolvedAt     DateTime  @default(now())
  resolutionNote String? // Optional explanation for the resolution
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, issueKey]) // issueKey is the reconciliation key
  @@index([workspaceId, issueKey])
  @@index([workspaceId, issueType])
  @@index([workspaceId, entityType, entityId])
  @@map("org_issue_resolutions")
}

