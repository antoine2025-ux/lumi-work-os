generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl temporarily commented out - using same URL for both
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String                 @unique
  emailVerified         DateTime?
  image                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  themePreference       String?                @default("default")
  bio                   String?
  skills                String[]               @default([])
  currentGoals          String[]               @default([])
  interests             String[]               @default([])
  timezone              String?
  location              String?
  phone                 String?
  linkedinUrl           String?
  githubUrl             String?
  personalWebsite       String?
  accounts              Account[]
  activities            Activity[]
  chatSessions          ChatSession[]
  onboarding_plans      OnboardingPlan[]
  orgAuditLogs          OrgAuditLog[]
  orgAuditActorLogs     OrgAuditLog[]          @relation("OrgAuditActor")
  orgAuditTargetLogs    OrgAuditLog[]          @relation("OrgAuditTargetUser")
  orgPositions          OrgPosition[]
  projectAssignees      ProjectAssignee[]      @relation("ProjectAssignee")
  projectMemberships    ProjectMember[]
  projectTemplates      ProjectTemplate[]
  projectWatchers       ProjectWatcher[]       @relation("ProjectWatcher")
  createdProjects       Project[]
  ownedProjects         Project[]              @relation("ProjectOwner")
  roleCards             RoleCard[]
  sessions              Session[]
  assignedSubtasks      Subtask[]
  taskComments          TaskComment[]
  taskHistory           TaskHistory[]
  createdTaskTemplates  TaskTemplate[]         @relation("TaskTemplateCreator")
  assignedTasks         Task[]                 @relation("TaskAssignee")
  createdTasks          Task[]                 @relation("TaskCreator")
  wiki_ai_interactions  wiki_ai_interactions[]
  wikiComments          WikiComment[]
  wiki_favorites        WikiFavorite[]
  wikiPagePermissions   WikiPagePermission[]
  wiki_page_views       wiki_page_views[]
  wikiPages             WikiPage[]
  wikiVersions          WikiVersion[]
  wiki_workspaces       wiki_workspaces[]
  workflowAssignments   WorkflowAssignment[]
  workflowInstances     WorkflowInstance[]
  workspaceMemberships  WorkspaceMember[]
  ownedWorkspaces       Workspace[]            @relation("WorkspaceOwner")
  onboarding_tasks      OnboardingTask[]       @relation("OnboardingTaskToUser")
  orgLoopbrainQueryLogs OrgLoopbrainQueryLog[]
  orgLoopbrainQueries   OrgLoopbrainQuery[]
  orgInvitations        OrgInvitation[]        @relation("InvitedBy")
  orgActivityExports    OrgActivityExport[]
  availability          PersonAvailability[]
  allocations           ProjectAllocation[]
  createdTodos          Todo[]                 @relation("TodoCreator")
  assignedTodos         Todo[]                 @relation("TodoAssignee")
  loopbrainUserProfiles LoopbrainUserProfile[]
  loopbrainChatFeedback LoopbrainChatFeedback[]
  loopbrainOpenLoops    LoopbrainOpenLoop[]
  ledTeams              OrgTeam[]              @relation("TeamLeader")
  
  // Goals & OKRs relations
  ownedGoals            Goal[]                 @relation("GoalOwner")
  createdGoals          Goal[]                 @relation("GoalCreatedBy")
  goalComments          GoalComment[]          @relation("GoalCommenter")
  goalUpdates           GoalUpdate[]           @relation("GoalUpdater")
  keyResultUpdates      KeyResultUpdate[]      @relation("KeyResultUpdater")
  createdGoalTemplates  GoalTemplate[]         @relation("GoalTemplateCreator")
  
  // Enterprise OKR relations
  goalStakeholders      GoalStakeholder[]      @relation("GoalStakeholders")
  goalApprovals         GoalApproval[]         @relation("GoalApprovers")
  goalProgressUpdates   GoalProgressUpdate[]   @relation("GoalProgressUpdater")
  employeeReviews       PerformanceReview[]    @relation("EmployeeReviews")
  managerReviews        PerformanceReview[]    @relation("ManagerReviews")
  employeeOneOnOnes     OneOnOneMeeting[]      @relation("Employee1on1s")
  managerOneOnOnes      OneOnOneMeeting[]      @relation("Manager1on1s")
  managerSeries         OneOnOneSeries[]       @relation("ManagerSeries")
  employeeSeries        OneOnOneSeries[]       @relation("EmployeeSeries")
  goalCheckIns          GoalCheckIn[]          @relation("GoalCheckIns")
  createdPerformanceCycles PerformanceCycle[]   @relation("CycleCreator")
  projectSpaceMemberships ProjectSpaceMember[]
  projectPersonLinks      ProjectPersonLink[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Workspace {
  id                             String                     @id @default(cuid())
  name                           String
  slug                           String                     @unique
  description                    String?
  logo                           String?
  createdAt                      DateTime                   @default(now())
  updatedAt                      DateTime                   @updatedAt
  ownerId                        String
  orgCenterOnboardingCompletedAt DateTime? // Org Center onboarding completion timestamp
  
  // Phase 1: Workspace onboarding fields
  mission              String?   // Company mission/description
  industry             String?   // Industry vertical
  companySize          String?   // "1-10", "11-50", "51-200", "201-500", "501+"
  timezone             String?   // IANA timezone (e.g., "America/New_York")
  onboardingCompletedAt DateTime? // Timestamp when onboarding finished
  
  chatSessions                   ChatSession[]
  featureFlags                   FeatureFlag[]
  integrations                   Integration[]
  migrations                     Migration[]
  onboardingPlans                OnboardingPlan[]
  onboardingTemplates            OnboardingTemplate[]
  orgAuditLogs                   OrgAuditLog[]
  orgDepartments                 OrgDepartment[]
  orgPositions                   OrgPosition[]
  orgQnaLogs                     OrgQnaLog[]
  orgLoopbrainQueryLogs          OrgLoopbrainQueryLog[]
  orgLoopbrainQueries            OrgLoopbrainQuery[]
  orgTeams                       OrgTeam[]
  orgActivityExports             OrgActivityExport[]
  orgSavedViews                  OrgSavedView[]
  orgIntelligenceSnapshots       OrgIntelligenceSnapshot[]
  orgIntelligenceSettings        OrgIntelligenceSettings?
  orgUiPreferences               OrgUiPreference[]
  orgIssueResolutions            OrgIssueResolution[]
  activities                     Activity[]
  projectTemplates               ProjectTemplate[]
  projects                       Project[]
  roleCards                      RoleCard[]
  taskTemplates                  TaskTemplate[]
  tasks                          Task[]
  wikiChunks                     WikiChunk[]
  wikiPages                      WikiPage[]
  wiki_workspaces                wiki_workspaces[]
  workflowInstances              WorkflowInstance[]
  workflows                      Workflow[]
  members                        WorkspaceMember[]
  orgInvitations                 OrgInvitation[]
  orgCustomRoles                 OrgCustomRole[]
  owner                          User                       @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  personAvailabilities           PersonAvailability[]
  personAvailabilityHealth       PersonAvailabilityHealth[]
  ownerAssignments               OwnerAssignment[]
  personManagerLinks             PersonManagerLink[]

  // Phase G: Capacity & Availability Foundation
  capacityContracts CapacityContract[]
  workAllocations   WorkAllocation[]
  roleCoverages     RoleCoverage[]

  // Phase H: Work Intake Sizing
  workRequests       WorkRequest[]
  workEffortDefaults WorkEffortDefaults?

  // Phase I: Decision Authority Mapping
  decisionDomains DecisionDomain[]

  // Phase J: Impact & Dependency Graph
  workImpacts WorkImpact[]

  // Phase K: Role Responsibilities Canon
  responsibilityTags          ResponsibilityTag[]
  roleResponsibilityProfiles  RoleResponsibilityProfile[]
  personResponsibilityOverrides PersonResponsibilityOverride[]

  // Settings IA: Org Capacity Settings
  orgCapacitySettings OrgCapacitySettings?

  // Capacity v1: Team Demand Planning
  teamCapacityPlans TeamCapacityPlan[]

  // Todos
  todos Todo[]

  // Loopbrain personalization
  loopbrainUserProfiles  LoopbrainUserProfile[]
  loopbrainChatFeedback  LoopbrainChatFeedback[]
  loopbrainOpenLoops     LoopbrainOpenLoop[]
  loopbrainPendingActions LoopbrainPendingAction[]
  projectSpaces           ProjectSpace[]

  // Loopbrain proactive insights
  proactiveInsights ProactiveInsight[]

  // W1.5: Recommendation Closure
  workRecommendationLogs WorkRecommendationLog[]

  // Foundation: Org ↔ Loopbrain Integration
  personRelationships    PersonRelationship[]
  personActivityMetrics  PersonActivityMetric[]
  leaveRequests          LeaveRequest[]
  onboardingProgress     OnboardingProgress?
  
  // Phase 1: Workspace onboarding state
  onboardingState        WorkspaceOnboardingState?
  
  // Goals & OKRs
  goals               Goal[]
  goalTemplates        GoalTemplate[]
  
  // Enterprise OKR
  performanceReviews   PerformanceReview[]
  performanceCycles    PerformanceCycle[]
  reviewQuestions       ReviewQuestion[]
  reviewResponses       ReviewResponse[]
  oneOnOneTemplates      OneOnOneTemplate[]
  oneOnOneMeetings       OneOnOneMeeting[]
  oneOnOneSeries         OneOnOneSeries[]
  oneOnOneTalkingPoints  OneOnOneTalkingPoint[]
  oneOnOneActionItems    OneOnOneActionItem[]
  goalWorkflowRules      GoalWorkflowRule[]

  // Workspace-scoped child models (added for direct workspaceId scoping)
  // Task children
  subtasks                    Subtask[]
  taskComments                TaskComment[]
  taskHistories               TaskHistory[]
  customFieldVals             CustomFieldVal[]
  // Project children
  projectMembers              ProjectMember[]
  projectWatchers             ProjectWatcher[]
  projectAssignees            ProjectAssignee[]
  projectPersonLinks          ProjectPersonLink[]
  projectDocumentation        ProjectDocumentation[]
  projectAccountabilities     ProjectAccountability[]
  projectDailySummaries       ProjectDailySummary[]
  customFieldDefs             CustomFieldDef[]
  // WikiPage children
  wikiVersions                WikiVersion[]
  wikiComments                WikiComment[]
  wikiEmbeds                  WikiEmbed[]
  wikiAttachments             WikiAttachment[]
  wikiPagePermissions         WikiPagePermission[]
  wikiFavorites               WikiFavorite[]
  wikiAiInteractions          wiki_ai_interactions[]
  wikiPageViews               wiki_page_views[]
  // Goal children
  objectives                  Objective[]
  goalComments                GoalComment[]
  goalUpdates                 GoalUpdate[]
  projectGoalLinks            ProjectGoalLink[]
  goalStakeholders            GoalStakeholder[]
  goalApprovals               GoalApproval[]
  goalProgressUpdates         GoalProgressUpdate[]
  goalAnalytics               GoalAnalytics[]
  goalRecommendations         GoalRecommendation[]
  goalCheckIns                GoalCheckIn[]
  // Goal grandchildren
  keyResults                  KeyResult[]
  keyResultUpdates            KeyResultUpdate[]
  // Other parent chains
  chatMessages                ChatMessage[]
  onboardingTasks             OnboardingTask[]
  onboardingTaskAssignments   onboarding_task_assignments[]
  taskTemplateItems           TaskTemplateItem[]
  workflowAssignments         WorkflowAssignment[]
  roleCardSkills              RoleCardSkill[]
  // Decision domain children
  decisionAuthorities         DecisionAuthority[]
  decisionEscalationSteps     DecisionEscalationStep[]

  @@map("workspaces")
}

model WorkspaceMember {
  id           String         @id @default(cuid())
  workspaceId  String
  userId       String
  role         WorkspaceRole  @default(MEMBER)
  joinedAt     DateTime       @default(now())
  customRoleId String?
  customRole   OrgCustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  preferences  Json? // User-level org preferences (filters, view settings, etc.)

  // Phase 2: Employment status for HRIS-lite tracking
  employmentStatus    EmploymentStatus @default(ACTIVE)
  employmentStartDate DateTime? // Start date of employment
  employmentEndDate   DateTime? // End date (for terminated/contractor)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // W1.5: Recommendation Closure
  acknowledgedRecommendations WorkRecommendationLog[]

  @@unique([workspaceId, userId])
  @@index([userId], map: "idx_workspace_members_user")
  @@index([userId, workspaceId], map: "idx_workspace_members_user_workspace")
  @@index([workspaceId, customRoleId])
  @@index([workspaceId, role], map: "idx_workspace_members_workspace_role")
  @@index([workspaceId, joinedAt(sort: Desc)], map: "idx_workspace_members_workspace_joined")
  @@index([workspaceId, employmentStatus])
  @@map("workspace_members")
}

enum ProjectSpaceVisibility {
  PUBLIC
  TARGETED
}

model ProjectSpace {
  id          String                 @id @default(cuid())
  workspaceId String
  name        String
  description String?
  visibility  ProjectSpaceVisibility @default(PUBLIC)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     ProjectSpaceMember[]

  @@index([workspaceId], map: "idx_project_spaces_workspace")
  @@map("project_spaces")
}

model ProjectSpaceMember {
  id             String      @id @default(cuid())
  projectSpaceId String
  userId         String
  joinedAt       DateTime    @default(now())
  projectSpace   ProjectSpace @relation(fields: [projectSpaceId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectSpaceId, userId], name: "project_space_members_projectSpaceId_userId_key")
  @@index([userId], map: "idx_project_space_members_user")
  @@index([projectSpaceId], map: "idx_project_space_members_space")
  @@map("project_space_members")
}

// Phase 1: Workspace onboarding state tracking
model WorkspaceOnboardingState {
  id                String    @id @default(cuid())
  workspaceId       String    @unique
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Checklist steps (for future phases)
  profileSetup      Boolean   @default(false)
  orgStructure      Boolean   @default(false)
  firstDepartment   Boolean   @default(false)
  firstTeam         Boolean   @default(false)
  firstInvite       Boolean   @default(false)
  
  // Admin profile data captured during onboarding
  adminName         String?
  adminRole         String?
  adminDepartment   String?   // Intent, not actual department ID yet
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([workspaceId])
  @@map("workspace_onboarding_states")
}

// Phase 2: Employment status for HRIS-lite tracking
enum EmploymentStatus {
  ACTIVE // Currently employed and working
  ON_LEAVE // On extended leave but still employed
  TERMINATED // No longer employed
  CONTRACTOR // External contractor
}

model OrgCustomRole {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  key         String // short slug, e.g. "people-ops"
  name        String // display label, e.g. "People Ops"
  description String?

  // JSON array of capability strings, e.g. ["org:member:invite", "org:insights:view"]
  capabilities Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships WorkspaceMember[]

  @@unique([workspaceId, key])
  @@map("org_custom_roles")
}

enum ContentFormat {
  HTML
  JSON
}

model WikiPage {
  id                   String                 @id @default(cuid())
  workspaceId          String
  title                String
  slug                 String
  content              String
  contentJson          Json?
  contentFormat        ContentFormat           @default(HTML)
  textContent          String?
  excerpt              String?
  parentId             String?
  order                Int                    @default(0)
  isPublished          Boolean                @default(true)
  tags                 String[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  createdById          String
  permissionLevel      String                 @default("team")
  category             String                 @default("general")
  view_count           Int?                   @default(0)
  is_featured          Boolean?               @default(false)
  workspace_type       String?                @default("team") @db.VarChar(50)
  last_viewed_at       DateTime?              @db.Timestamp(6)
  ai_analysis          Json?
  quality_score        Decimal?               @db.Decimal(3, 2)
  projects                Project[]
  projectDocumentation    ProjectDocumentation[]
  wiki_ai_interactions wiki_ai_interactions[]
  attachments          WikiAttachment[]
  chunks               WikiChunk[]
  comments             WikiComment[]
  embeds               WikiEmbed[]
  wiki_favorites       WikiFavorite[]
  permissions          WikiPagePermission[]
  wiki_page_views      wiki_page_views[]
  createdBy            User                   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  parent               WikiPage?              @relation("WikiPageHierarchy", fields: [parentId], references: [id])
  children             WikiPage[]             @relation("WikiPageHierarchy")
  workspace            Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versions             WikiVersion[]

  @@unique([workspaceId, slug])
  @@index([last_viewed_at(sort: Desc)], map: "idx_wiki_pages_last_viewed")
  @@index([tags], map: "idx_wiki_pages_tags", type: Gin)
  @@index([view_count(sort: Desc)], map: "idx_wiki_pages_view_count")
  @@index([workspace_type], map: "idx_wiki_pages_workspace_type")
  @@index([workspaceId, updatedAt], map: "idx_wiki_pages_workspace_updated")
  @@index([workspaceId, isPublished], map: "idx_wiki_pages_workspace_published")
  @@index([workspaceId, workspace_type], map: "idx_wiki_pages_workspace_type_alt")
  @@index([updatedAt(sort: Desc)], map: "idx_wiki_pages_updated_at")
  @@map("wiki_pages")
}

model WikiFavorite {
  id           String    @id @default(cuid()) @db.VarChar(50)
  page_id      String    @db.VarChar(50)
  user_id      String    @db.VarChar(50)
  workspaceId  String
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  wiki_pages   WikiPage  @relation(fields: [page_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([page_id, user_id])
  @@index([page_id], map: "idx_wiki_favorites_page_id")
  @@index([user_id], map: "idx_wiki_favorites_user_id")
  @@index([user_id, page_id], map: "idx_wiki_favorites_user_workspace")
  @@index([workspaceId])
  @@map("wiki_favorites")
}

model WikiAttachment {
  id          String    @id @default(cuid())
  pageId      String
  workspaceId String
  fileName    String
  fileSize    Int
  fileType    String
  fileUrl     String
  createdAt   DateTime  @default(now())
  page        WikiPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("wiki_attachments")
}

model WikiComment {
  id          String    @id @default(cuid())
  pageId      String
  workspaceId String
  userId      String
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  page        WikiPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt(sort: Desc)], map: "idx_wiki_comments_page_created")
  @@index([workspaceId])
  @@map("wiki_comments")
}

model WikiVersion {
  id            String        @id @default(cuid())
  pageId        String
  workspaceId   String
  content       String
  contentJson   Json?
  contentFormat ContentFormat @default(HTML)
  textContent   String?
  version       Int
  createdAt     DateTime      @default(now())
  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
  page          WikiPage      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([pageId, version], map: "idx_wiki_versions_page_version")
  @@index([workspaceId])
  @@map("wiki_versions")
}

model WikiChunk {
  id          String    @id @default(cuid())
  pageId      String
  workspaceId String
  content     String
  metadata    Json?
  createdAt   DateTime  @default(now())
  page        WikiPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("wiki_chunks")
}

model WikiPagePermission {
  id          String         @id @default(cuid())
  pageId      String
  workspaceId String
  userId      String?
  role        WorkspaceRole?
  permission  String
  granted     Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  page        WikiPage       @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user        User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId, permission])
  @@index([pageId, userId], map: "idx_wiki_page_permissions_page_user")
  @@index([workspaceId])
  @@map("wiki_page_permissions")
}

model WikiEmbed {
  id          String    @id @default(cuid())
  pageId      String
  workspaceId String
  provider    String
  url         String?
  resourceId  String?
  title       String?
  description String?
  thumbnail   String?
  metadata    Json?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  page        WikiPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("wiki_embeds")
}

model OnboardingTemplate {
  id               String           @id @default(cuid())
  workspaceId      String
  name             String
  description      String?
  role             String?
  duration         Int
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  plans            OnboardingPlan[]
  onboarding_tasks OnboardingTask[]
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("onboarding_templates")
}

model OnboardingTask {
  id                          String                        @id @default(cuid())
  templateId                  String
  workspaceId                 String
  title                       String
  description                 String?
  order                       Int
  isRequired                  Boolean                       @default(true)
  estimatedMinutes            Int?
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime
  onboarding_task_assignments onboarding_task_assignments[]
  onboarding_templates        OnboardingTemplate            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  workspace                   Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  users                       User[]                        @relation("OnboardingTaskToUser")

  @@index([workspaceId])
  @@map("onboarding_tasks")
}

model OnboardingPlan {
  id                          String                        @id @default(cuid())
  workspaceId                 String
  templateId                  String?
  userId                      String
  title                       String
  status                      OnboardingStatus              @default(ACTIVE)
  startDate                   DateTime
  endDate                     DateTime?
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  template                    OnboardingTemplate?           @relation(fields: [templateId], references: [id])
  users                       User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace                   Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  onboarding_task_assignments onboarding_task_assignments[]

  @@index([userId, status], map: "idx_onboarding_plans_employee_status")
  @@map("onboarding_plans")
}

model OrgDepartment {
  id            String    @id @default(cuid())
  workspaceId   String
  name          String
  description   String?
  color         String?
  order         Int       @default(0)
  isActive      Boolean   @default(true)
  ownerPersonId String? // Person (via OrgPosition.userId) who owns this department
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teams         OrgTeam[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([ownerPersonId])
  @@map("org_departments")
}

model OrgTeam {
  id            String         @id @default(cuid())
  workspaceId   String
  departmentId  String? // Nullable: teams can be unassigned (unassigned is a STATE, not an ENTITY)
  name          String
  description   String?
  color         String?
  order         Int            @default(0)
  isActive      Boolean        @default(true)
  ownerPersonId String? // Person (via OrgPosition.userId) who owns this team
  leaderId      String? // Team leader (references User directly)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  positions     OrgPosition[]
  department        OrgDepartment?    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  workspace         Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leader            User?             @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  teamCapacityPlan  TeamCapacityPlan?
  projects          Project[]

  // Note: Unique constraint removed because Prisma doesn't support unique constraints with nullable fields
  // Uniqueness is enforced at the application level for teams within the same department
  @@index([workspaceId])
  @@index([workspaceId, isActive])  // Active teams listing
  @@index([departmentId])
  @@index([ownerPersonId])
  @@index([leaderId])
  @@map("org_teams")
}

