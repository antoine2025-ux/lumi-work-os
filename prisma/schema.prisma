}

// =============================================================================
// Goals & OKRs Models
// =============================================================================

/**
 * Goal - Strategic goals and OKRs system
 *
 * Supports hierarchical goals (company → department → team → individual)
 * with quarterly/annual periods and cascading progress tracking.
 */
model Goal {
  id          String     @id @default(cuid())
  workspaceId String
  title       String
  description String?
  
  // Goal hierarchy and scoping
  level       GoalLevel
  ownerId     String?
  parentId    String?
  
  // Timeline
  period      GoalPeriod
  startDate   DateTime
  endDate     DateTime
  quarter     String?
  
  // Status and progress
  status      GoalStatus @default(DRAFT)
  progress    Float      @default(0)
  
  // Alignment & performance integration
  alignmentScore   Float    @default(0) // 0-100% alignment with parent
  performanceWeight Float   @default(1.0) // Weight in performance reviews
  reviewCycle      String?  // e.g. "2026-Q1"
  
  // Metadata
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdById String
  
  // Relations
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner          User?             @relation("GoalOwner", fields: [ownerId], references: [id])
  createdBy      User              @relation("GoalCreatedBy", fields: [createdById], references: [id])
  parent         Goal?             @relation("GoalHierarchy", fields: [parentId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  children       Goal[]            @relation("GoalHierarchy")
  objectives     Objective[]
  linkedProjects ProjectGoalLink[]
  comments       GoalComment[]
  updates        GoalUpdate[]
  
  // Conflict tracking (self-relation)
  conflictsWith  Goal[]   @relation("GoalConflicts")
  conflictedWith Goal[]   @relation("GoalConflicts")
  
  // Enterprise relations
  stakeholders     GoalStakeholder[]
  approvals        GoalApproval[]
  progressUpdates  GoalProgressUpdate[]
  analytics        GoalAnalytics[]
  recommendations  GoalRecommendation[]
  checkIns         GoalCheckIn[]
  
  @@index([workspaceId])
  @@index([workspaceId, level])
  @@index([workspaceId, ownerId])
  @@index([workspaceId, quarter])
  @@index([workspaceId, status])
  @@index([parentId])
  @@index([workspaceId, level, reviewCycle])
  @@map("goals")
}

/**
 * Objective - Key objectives within a goal (the "O" in OKR)
 */
model Objective {
  id          String           @id @default(cuid())
  goalId      String
  workspaceId String
  title       String
  description String?
  weight      Float            @default(1)
  
  // Progress tracking
  progress    Float            @default(0)
  status      ObjectiveStatus  @default(NOT_STARTED)
  
  // Metadata
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  // Relations
  goal        Goal             @relation(fields: [goalId], references: [id], onDelete: Cascade)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  keyResults  KeyResult[]
  
  @@index([goalId])
  @@index([workspaceId])
  @@map("objectives")
}

/**
 * KeyResult - Measurable key results within an objective (the "KR" in OKR)
 */
model KeyResult {
  id           String          @id @default(cuid())
  objectiveId  String
  workspaceId  String
  title        String
  description  String?
  
  // Measurement
  metricType   MetricType
  targetValue  Float
  currentValue Float           @default(0)
  unit         String?
  
  // Progress
  progress     Float           @default(0)
  status       KeyResultStatus @default(NOT_STARTED)
  
  // Timeline
  dueDate      DateTime?
  
  // Metadata
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  
  // Relations
  objective    Objective       @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updates      KeyResultUpdate[]
  
  @@index([objectiveId])
  @@index([workspaceId])
  @@map("key_results")
}

/**
 * KeyResultUpdate - History of key result value changes
 */
model KeyResultUpdate {
  id            String    @id @default(cuid())
  keyResultId   String
  workspaceId   String
  previousValue Float
  newValue      Float
  note          String?
  updatedById   String
  createdAt     DateTime  @default(now())
  
  keyResult     KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updatedBy     User      @relation("KeyResultUpdater", fields: [updatedById], references: [id])
  
  @@index([keyResultId])
  @@index([createdAt])
  @@index([workspaceId])
  @@map("key_result_updates")
}

/**
 * GoalComment - Comments and discussions on goals
 */
model GoalComment {
  id          String    @id @default(cuid())
  goalId      String
  workspaceId String
  content     String
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author      User      @relation("GoalCommenter", fields: [authorId], references: [id])
  
  @@index([goalId])
  @@index([createdAt])
  @@index([workspaceId])
  @@map("goal_comments")
}

/**
 * GoalUpdate - Activity log for goal changes
 */
model GoalUpdate {
  id           String         @id @default(cuid())
  goalId       String
  workspaceId  String
  updateType   GoalUpdateType
  content      String
  previousData Json?
  newData      Json?
  authorId     String
  createdAt    DateTime       @default(now())
  
  goal         Goal           @relation(fields: [goalId], references: [id], onDelete: Cascade)
  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author       User           @relation("GoalUpdater", fields: [authorId], references: [id])
  
  @@index([goalId])
  @@index([createdAt])
  @@index([workspaceId])
  @@map("goal_updates")
}

/**
 * ProjectGoalLink - Many-to-many relationship between projects and goals
 */
model ProjectGoalLink {
  id               String           @id @default(cuid())
  goalId           String
  projectId        String
  workspaceId      String
  createdAt        DateTime         @default(now())
  
  // Contribution tracking
  contributionType ContributionType @default(CONTRIBUTING)
  expectedImpact   Float            @default(50) // 0-100%
  actualImpact     Float            @default(0)
  
  // Auto-sync configuration
  autoUpdate       Boolean          @default(true)
  syncRules        Json?            // Rules for automatic progress updates
  
  goal             Goal             @relation(fields: [goalId], references: [id], onDelete: Cascade)
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  @@unique([goalId, projectId])
  @@index([goalId])
  @@index([projectId])
  @@index([workspaceId])
  @@map("project_goal_links")
}

/**
 * GoalTemplate - Reusable goal templates for quick goal creation
 */
model GoalTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  description String?
  level       GoalLevel
  template    Json
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  createdById String
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("GoalTemplateCreator", fields: [createdById], references: [id])
  
  @@index([workspaceId])
  @@index([workspaceId, level])
  @@index([workspaceId, isActive])
  @@map("goal_templates")
}

// ============================================================================
// Enterprise OKR Models (Phase A: Cascading Goals + Project Integration)
// ============================================================================

/**
 * GoalStakeholder - People involved in a goal with specific roles
 */
model GoalStakeholder {
  id          String          @id @default(cuid())
  goalId      String
  workspaceId String
  userId      String
  role        StakeholderRole
  canEdit     Boolean         @default(false)
  canApprove  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  
  goal        Goal            @relation(fields: [goalId], references: [id], onDelete: Cascade)
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User            @relation("GoalStakeholders", fields: [userId], references: [id])
  
  @@unique([goalId, userId])
  @@index([goalId])
  @@index([userId])
  @@index([workspaceId])
  @@map("goal_stakeholders")
}

/**
 * GoalApproval - Approval workflow for goal changes
 */
model GoalApproval {
  id          String         @id @default(cuid())
  goalId      String
  workspaceId String
  approverId  String
  status      ApprovalStatus @default(PENDING)
  comment     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  goal        Goal           @relation(fields: [goalId], references: [id], onDelete: Cascade)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  approver    User           @relation("GoalApprovers", fields: [approverId], references: [id])
  
  @@index([goalId])
  @@index([approverId, status])
  @@index([workspaceId])
  @@map("goal_approvals")
}

/**
 * GoalProgressUpdate - Audit trail for goal progress changes
 */
model GoalProgressUpdate {
  id               String    @id @default(cuid())
  goalId           String
  workspaceId      String
  triggeredBy      String    // 'project_completion', 'manual_update', 'key_result_change', 'agent_action'
  sourceId         String?   // Project ID, Key Result ID, etc.
  
  previousProgress Float
  newProgress      Float
  confidence       Float     @default(1.0) // How confident is this update (0-1)
  
  createdAt        DateTime  @default(now())
  updatedById      String
  
  goal             Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updatedBy        User      @relation("GoalProgressUpdater", fields: [updatedById], references: [id])
  
  @@index([goalId, createdAt])
  @@index([updatedById])
  @@index([workspaceId])
  @@map("goal_progress_updates")
}

// ============================================================================
// Enterprise OKR Models (Phase B: Performance Management + Analytics)
// ============================================================================

/**
 * PerformanceReview - Goal-based performance evaluation
 */
model PerformanceReview {
  id           String       @id @default(cuid())
  workspaceId  String
  employeeId   String
  managerId    String
  period       String       // "2026-Q1", "2026-H1", "2026"
  status       ReviewStatus @default(DRAFT)
  
  // Cycle linkage (nullable for backward compat with existing flat reviews)
  cycleId      String?
  reviewerRole ReviewerRole @default(MANAGER)
  
  // Goal achievement scoring
  goalIds      String[]     // Goals evaluated in this review
  goalScores   Json?        // Goal ID -> achievement score
  overallScore Float?       // Calculated from goal achievement
  
  // Traditional review fields
  feedback     String?
  strengths    String?
  improvements String?
  nextGoals    String?
  
  // Employee sign-off
  acknowledgedAt DateTime?
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  employee     User         @relation("EmployeeReviews", fields: [employeeId], references: [id])
  manager      User         @relation("ManagerReviews", fields: [managerId], references: [id])
  cycle        PerformanceCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  responses    ReviewResponse[]
  
  @@unique([workspaceId, employeeId, period, reviewerRole])
  @@index([workspaceId, managerId, status])
  @@index([workspaceId, period])
  @@index([workspaceId, cycleId])
  @@map("performance_reviews")
}

/**
 * PerformanceCycle - Groups reviews into admin-managed review cycles
 */
model PerformanceCycle {
  id          String          @id @default(cuid())
  workspaceId String
  name        String          // "Q1 2026 Review"
  description String?
  status      CycleStatus     @default(SETUP)
  reviewType  CycleReviewType @default(COMBINED)
  
  startDate   DateTime
  endDate     DateTime
  dueDate     DateTime        // Deadline for all reviews
  
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User            @relation("CycleCreator", fields: [createdById], references: [id])
  questions   ReviewQuestion[]
  reviews     PerformanceReview[]
  
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("performance_cycles")
}

/**
 * ReviewQuestion - Structured questions/rubrics per cycle
 */
model ReviewQuestion {
  id          String       @id @default(cuid())
  cycleId     String
  workspaceId String
  text        String
  description String?
  type        QuestionType @default(RATING_AND_TEXT)
  sortOrder   Int          @default(0)
  isRequired  Boolean      @default(true)
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  cycle       PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  responses   ReviewResponse[]
  
  @@index([cycleId])
  @@index([workspaceId])
  @@map("review_questions")
}

/**
 * ReviewResponse - Per-question answer linked to a specific review
 */
model ReviewResponse {
  id          String   @id @default(cuid())
  reviewId    String
  questionId  String
  workspaceId String
  rating      Int?     // 1-5 scale
  text        String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  review      PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  question    ReviewQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  @@unique([reviewId, questionId])
  @@index([reviewId])
  @@index([questionId])
  @@index([workspaceId])
  @@map("review_responses")
}

/**
 * OneOnOneTemplate - Reusable templates for 1:1 meetings
 */
model OneOnOneTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  sections    Json      // Goal progress, blockers, feedback, development
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  @@index([workspaceId])
  @@map("one_on_one_templates")
}

/**
 * OneOnOneSeries - Recurring 1:1 meeting series between manager and report
 */
model OneOnOneSeries {
  id          String   @id @default(cuid())
  workspaceId String
  managerId   String
  employeeId  String
  frequency   String   // WEEKLY, BIWEEKLY, MONTHLY
  dayOfWeek   Int?     // 0-6 for recurring scheduling (0=Sunday)
  duration    Int      @default(30) // minutes
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  manager     User             @relation("ManagerSeries", fields: [managerId], references: [id])
  employee    User             @relation("EmployeeSeries", fields: [employeeId], references: [id])
  meetings    OneOnOneMeeting[]

  @@unique([managerId, employeeId, workspaceId])
  @@index([workspaceId])
  @@index([managerId])
  @@index([employeeId])
  @@map("one_on_one_series")
}

/**
 * OneOnOneMeeting - 1:1 meetings with goal progress discussion
 */
model OneOnOneMeeting {
  id              String        @id @default(cuid())
  workspaceId     String
  employeeId      String
  managerId       String
  seriesId        String?
  scheduledAt     DateTime
  status          MeetingStatus @default(SCHEDULED)
  calendarEventId String?       // Google Calendar event ID (if linked)
  
  // Goal-related discussion (legacy fields, kept for backward compat)
  goalProgress Json?            // Goal ID -> discussion notes
  blockers     String?
  support      String?
  nextActions  String?

  // Rich notes
  managerNotes  String?  @db.Text
  employeeNotes String?  @db.Text
  sharedNotes   String?  @db.Text
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  workspace      Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  employee       User                   @relation("Employee1on1s", fields: [employeeId], references: [id])
  manager        User                   @relation("Manager1on1s", fields: [managerId], references: [id])
  series         OneOnOneSeries?        @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  talkingPoints  OneOnOneTalkingPoint[]
  actionItems    OneOnOneActionItem[]
  
  @@index([workspaceId, employeeId])
  @@index([workspaceId, managerId])
  @@index([scheduledAt])
  @@index([seriesId])
  @@map("one_on_one_meetings")
}

/**
 * OneOnOneTalkingPoint - Discussion topics for a 1:1 meeting
 */
model OneOnOneTalkingPoint {
  id          String   @id @default(cuid())
  workspaceId String
  meetingId   String
  content     String
  addedBy     String   // userId who added this point
  isDiscussed Boolean  @default(false)
  source      String?  // GOAL, REVIEW, ACTION_ITEM, MANUAL
  sourceId    String?  // goalId, reviewId, or actionItemId if auto-generated
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  meeting     OneOnOneMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([meetingId])
  @@map("one_on_one_talking_points")
}

/**
 * OneOnOneActionItem - Action items from 1:1 meetings
 */
model OneOnOneActionItem {
  id          String    @id @default(cuid())
  workspaceId String
  meetingId   String
  content     String
  assigneeId  String    // userId responsible
  status      String    @default("OPEN") // OPEN, DONE, CANCELLED
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  meeting     OneOnOneMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([meetingId])
  @@index([assigneeId])
  @@map("one_on_one_action_items")
}

/**
 * GoalAnalytics - Computed analytics for goal intelligence (on-write)
 */
model GoalAnalytics {
  id                    String    @id @default(cuid())
  goalId                String
  workspaceId           String
  period                String    // "daily", "weekly", etc.
  
  // Progress metrics
  progressVelocity      Float     // Rate of progress change
  projectedCompletion   DateTime? // Estimated completion date
  riskScore             Float     // 0-100 risk of missing goal
  
  // Engagement metrics
  updateFrequency       Float     // How often goal is updated (updates/week)
  stakeholderEngagement Float     @default(0)
  
  // Performance correlations
  teamProductivity      Float?
  projectAlignment      Float?
  
  calculatedAt          DateTime  @default(now())
  
  goal                  Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  @@unique([goalId, period])
  @@index([riskScore])
  @@index([workspaceId])
  @@map("goal_analytics")
}

/**
 * GoalRecommendation - AI-generated recommendations for goal achievement
 */
model GoalRecommendation {
  id              String                 @id @default(cuid())
  goalId          String
  workspaceId     String
  type            RecommendationType
  priority        RecommendationPriority
  
  title           String
  description     String
  suggestedActions Json                  // Actionable steps
  
  // Agent-ready fields
  automatable     Boolean                @default(false)
  confidence      Float                  // How confident is this recommendation (0-1)
  impact          Float                  // Expected impact if implemented (0-1)
  
  status          RecommendationStatus   @default(PENDING)
  implementedAt   DateTime?
  feedback        String?
  
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  
  goal            Goal                   @relation(fields: [goalId], references: [id], onDelete: Cascade)
  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  @@index([goalId, status])
  @@index([priority, status])
  @@index([workspaceId])
  @@map("goal_recommendations")
}

// ============================================================================
// Enterprise OKR Models (Phase C: Workflow Automation + Agent)
// ============================================================================

/**
 * GoalCheckIn - Periodic check-ins on goal progress
 */
model GoalCheckIn {
  id               String    @id @default(cuid())
  goalId           String
  workspaceId      String
  userId           String
  period           String    // "2026-W07" for weekly check-ins
  
  progressUpdate   Float?
  blockers         String?
  support          String?
  confidence       Float?    // Confidence in achieving goal (0-1)
  
  // Auto-generated fields
  systemUpdates    Json?     // What system auto-updated
  recommendations  Json?     // AI-generated suggestions
  
  createdAt        DateTime  @default(now())
  
  goal             Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user             User      @relation("GoalCheckIns", fields: [userId], references: [id])
  
  @@unique([goalId, userId, period])
  @@index([goalId, createdAt])
  @@index([workspaceId])
  @@map("goal_check_ins")
}

/**
 * GoalWorkflowRule - Automated workflow rules for goals
 */
model GoalWorkflowRule {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  trigger     WorkflowTrigger
  conditions  Json            // When to execute
  actions     Json            // What to do
  
  isActive    Boolean         @default(true)
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  @@index([workspaceId, isActive])
  @@index([trigger])
  @@map("goal_workflow_rules")
}

model OnboardingProgress {
  id                    String    @id @default(uuid())
  workspaceId           String    @unique
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  currentStep           Int       @default(1)
  completedSteps        Int[]     @default([])

  orgBasicsComplete     Boolean   @default(false)
  departmentsCreated    Boolean   @default(false)
  teamsCreated          Boolean   @default(false)
  peopleInvited         Boolean   @default(false)
  capacitySet           Boolean   @default(false)
  integrationsConnected Boolean   @default(false)

  orgName               String?
  orgIndustry           String?
  orgSize               String?
  skipReason            String?

  isComplete            Boolean   @default(false)
  completedAt           DateTime?
  skippedAt             DateTime?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([workspaceId, isComplete])
  @@map("onboarding_progress")
}
