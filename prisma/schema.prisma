// ============================================================================
// Loopbrain Context Store Models
// ============================================================================

/**
 * ContextItem - Canonical storage for ContextObject instances
 * Stores the full serialized ContextObject in JSON format for queryable persistence
 */
model ContextItem {
  id          String   @id @default(cuid())
  contextId   String // Original entity ID (pageId, projectId, taskId, etc.)
  workspaceId String
  type        String // ContextType enum value (workspace, page, project, task, org, activity, unified)
  title       String
  summary     String? // Optional human-readable summary
  data        Json // Full serialized ContextObject (entire object, not partial)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  // Relations
  embedding       ContextEmbedding?
  summaryRelation ContextSummary?

  // Indexes for efficient multi-tenant queries
  @@index([workspaceId, type], map: "idx_context_items_workspace_type")
  @@index([contextId, type], map: "idx_context_items_context_type")
  @@index([workspaceId, updatedAt(sort: Desc)], map: "idx_context_items_workspace_updated")
  @@map("context_items")
}

/**
 * ContextEmbedding - Vector storage for semantic search
 * Stores embeddings for ContextItem instances to enable vector similarity search
 * TODO: Replace Float[] with Vector type after enabling pgvector extension in Step 4
 * TODO: Add vector index: @@index([embedding], type: "vector") after pgvector setup
 */
model ContextEmbedding {
  id            String   @id @default(cuid())
  contextItemId String   @unique
  embedding     Float[] // TODO: Replace with Vector type after enabling pgvector extension
  workspaceId   String
  updatedAt     DateTime @updatedAt

  // Relation
  contextItem ContextItem @relation(fields: [contextItemId], references: [id], onDelete: Cascade)

  // Indexes for efficient multi-tenant queries
  @@index([workspaceId], map: "idx_context_embeddings_workspace")
  // TODO: Add vector index after pgvector: @@index([embedding], type: "vector")
  @@map("context_embeddings")
}

/**
 * ContextSummary - Pre-computed LLM-generated summaries
 * Stores cached text summaries for ContextItem instances to reduce LLM calls
 */
model ContextSummary {
  id            String   @id @default(cuid())
  contextItemId String   @unique
  summary       String // Pre-computed text summary
  workspaceId   String
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  // Relation
  contextItem ContextItem @relation(fields: [contextItemId], references: [id], onDelete: Cascade)

  // Indexes for efficient multi-tenant queries
  @@index([workspaceId], map: "idx_context_summaries_workspace")
  @@map("context_summaries")
}

/**
 * OrgQnaLog - Logs all Org Q&A requests for analytics and audit
 * Tracks questions asked, location, and metadata for future Loopbrain quality evaluation
 */
model OrgQnaLog {
  id          String   @id @default(uuid())
  workspaceId String
  question    String
  location    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  // Relation
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Indexes for efficient multi-tenant queries
  @@index([workspaceId, createdAt], map: "idx_org_qna_log_workspace_created")
  @@index([workspaceId, location], map: "idx_org_qna_log_workspace_location")
  @@map("org_qna_log")
}

/**
 * OrgLoopbrainQueryLog - Logs Org-aware Loopbrain queries for analytics
 * Tracks questions, answers, and context usage to analyze Org intelligence usage patterns
 */
model OrgLoopbrainQueryLog {
  id                String   @id @default(cuid())
  workspaceId       String
  userId            String?
  question          String
  answerPreview     String // trimmed snippet of the answer
  contextItemsCount Int
  metadata          Json?
  createdAt         DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_org_lb_query_workspace_created")
  @@index([userId, createdAt(sort: Desc)], map: "idx_org_lb_query_user_created")
  @@map("org_loopbrain_query_logs")
}

/**
 * OrgLoopbrainQuery - Telemetry for Org Loopbrain queries
 * Tracks question types, context usage, and referenced tags for analytics
 */
model OrgLoopbrainQuery {
  id              String   @id @default(cuid())
  workspaceId     String
  userId          String?
  question        String
  questionType    String // headcount | reporting | risk | generic | unknown
  contextType     String // org.headcount | org.reporting | org.risk | org.generic
  hasOrgRoot      Boolean
  peopleCount     Int
  teamCount       Int
  departmentCount Int
  roleCount       Int
  referencedTags  String[] @default([]) // e.g. ["org_health_label:stable", "org_depth:3"]
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt], map: "idx_org_lb_query_telemetry_workspace_created")
  @@index([workspaceId, questionType], map: "idx_org_lb_query_telemetry_workspace_qtype")
  @@map("org_loopbrain_queries")
}

