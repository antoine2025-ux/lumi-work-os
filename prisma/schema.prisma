  state          Json // filters, sort, query, fixQueue
  shared         Boolean  @default(false)
  pinned         Boolean  @default(false)
  defaultForRole OrgRole?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orgId, scope])
  @@index([orgId, userId])
  @@index([orgId, pinned])
  @@map("saved_views")
