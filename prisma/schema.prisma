  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships OrgMembership[]
  invitations OrgInvitation[]
  audit       AuditLogEntry[]
  roles       Role[]

  @@index([name])
  @@map("orgs")
}

enum OrgRole {
  VIEWER
  EDITOR
  ADMIN
}

model SavedView {
  id             String   @id @default(cuid())
  orgId          String
  userId         String? // null when system/shared
  name           String
  scope          String // e.g. "people"
  state          Json // filters, sort, query, fixQueue
  shared         Boolean  @default(false)
  pinned         Boolean  @default(false)
  defaultForRole OrgRole?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orgId, scope])
  @@index([orgId, userId])
  @@index([orgId, pinned])
  @@map("saved_views")
}

model OrgPersonIssue {
  id          String    @id @default(cuid())
  orgId       String
  personId    String
  type        String // e.g. "MISSING_MANAGER"
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  resolvedAt  DateTime?

  // Phase 1: Issue resolution tracking for LoopBrain reasoning
  resolution     IssueResolution @default(PENDING)
  resolutionNote String? // Optional explanation for ACKNOWLEDGED/FALSE_POSITIVE
  resolvedById   String? // User who resolved the issue

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, personId, type])
  @@index([orgId, type, resolvedAt])
  @@index([orgId, resolution])
  @@map("org_person_issues")
}

// Phase 1: Issue resolution states for structural integrity tracking
enum IssueResolution {
  PENDING // Issue not yet addressed
  ACKNOWLEDGED // Issue is known and intentional
  FALSE_POSITIVE // Issue was incorrectly flagged
  RESOLVED // Issue has been fixed
}

// Hybrid issues storage: derive on-demand, store resolved by issueKey for reconciliation
model OrgIssueResolution {
  id             String    @id @default(cuid())
  workspaceId    String
  issueKey       String // PRIMARY IDENTIFIER: `${issueType}:${entityType}:${entityId}` (e.g., "OWNERSHIP_CONFLICT:TEAM:c123")
  issueType      String // e.g., "OWNERSHIP_CONFLICT", "UNOWNED_TEAM"
  entityType     String // "TEAM", "DEPARTMENT", "PERSON", "POSITION"
  entityId       String // ID of the entity with the issue
  resolvedBy     String // userId - User who marked this as resolved
  resolvedAt     DateTime  @default(now())
  resolutionNote String? // Optional explanation for the resolution
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, issueKey]) // issueKey is the reconciliation key
  @@index([workspaceId, issueKey])
  @@index([workspaceId, issueType])
  @@index([workspaceId, entityType, entityId])
  @@map("org_issue_resolutions")
}

model OrgDuplicateCandidate {
  id         String   @id @default(cuid())
  orgId      String
  personAId  String
  personBId  String
  confidence Float
  reason     String? // e.g. "email_exact", "name_similar", "email_prefix+name"
  features   Json?
  status     String   @default("OPEN") // OPEN | DISMISSED | MERGED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([orgId, personAId, personBId])
  @@index([orgId, status, confidence])
  @@map("org_duplicate_candidates")
}

model OrgPersonMergeLog {
  id                   String    @id @default(cuid())
  orgId                String
  canonicalId          String
  mergedId             String
  snapshot             Json // copy of merged record before merge (for undo)
  reportRewireSnapshot Json? // ids of reports rewired from merged -> canonical
  appliedAt            DateTime  @default(now())
  undoneAt             DateTime?
  actorUserId          String?
  actorLabel           String

  @@unique([orgId, canonicalId, mergedId, undoneAt])
  @@index([orgId, appliedAt])
  @@map("org_person_merge_logs")
}

model OrgSuggestionRun {
  id        String   @id @default(cuid())
  orgId     String
  scope     String // e.g. "people_issues"
  inputHash String
  output    Json
  engineId  String?
  modelId   String?
  createdAt DateTime @default(now())

  @@index([orgId, scope, createdAt])
  @@index([orgId, engineId, createdAt])
  @@map("org_suggestion_runs")
}

model OrgLoopBrainConfig {
  id        String   @id @default(cuid())
  orgId     String
  scope     String // "people_issues"
  engineId  String // e.g. "heuristic-v1"
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, scope])
  @@index([orgId, scope, enabled])
  @@map("org_loop_brain_configs")
}

model LoopBrainModel {
  id        String   @id @default(cuid())
  name      String // e.g. "heuristic-v1", "llm-v0.1"
  scope     String // e.g. "people_issues"
  active    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([scope, active])
  @@map("loop_brain_models")
}

model LoopBrainFeedback {
  id               String   @id @default(cuid())
  orgId            String
  personId         String?
  suggestionRunId  String?
  modelId          String?
  scope            String
  confidence       Float?
  accepted         Boolean?
  partiallyApplied Boolean?
  feedback         String? // free-text (optional)
  createdAt        DateTime @default(now())

  @@index([orgId, scope, createdAt])
  @@map("loop_brain_feedback")
}

model LoopBrainOutcome {
  id              String   @id @default(cuid())
  orgId           String
  suggestionRunId String
  scope           String
  beforeMetrics   Json // e.g. { missingManagerCount: 14 }
  afterMetrics    Json // e.g. { missingManagerCount: 6 }
  improved        Boolean
  measuredAt      DateTime @default(now())

  @@index([orgId, scope, measuredAt])
  @@map("loop_brain_outcomes")
}

model OrgLoopBrainRollout {
  id        String   @id @default(cuid())
  orgId     String
  scope     String // "people_issues"
  mode      String // "ALL" | "ADMIN_ONLY" | "MANAGERS_ONLY" | "TEAM"
  teamName  String? // used when mode === "TEAM"
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, scope])
  @@map("org_loop_brain_rollouts")
}

model OrgIntelligenceSnapshot {
  id           String   @id @default(cuid())
  workspaceId  String
  createdAt    DateTime @default(now())
  source       String // e.g. "on_demand", "nightly"
  findingCount Int
  findingsJson Json // Full array of findings for durability + reindex
  rollupsJson  Json? // Computed rollups (bySignal, bySeverity, totals)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("org_intelligence_snapshots")
}

model OrgIntelligenceSettings {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Management load thresholds
  mgmtMediumDirectReports Int @default(5)
  mgmtHighDirectReports   Int @default(9)

  // Availability staleness window (days)
  availabilityStaleDays Int @default(14)

  // Snapshot freshness policy (minutes)
  snapshotFreshMinutes Int @default(1440) // 24h recommended freshness window
  snapshotWarnMinutes  Int @default(2880) // 48h warn threshold

  // Snapshot schema version (for future migrations)
  schemaVersion Int @default(1)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("org_intelligence_settings")
}

// Settings IA: Capacity thresholds configuration
model OrgCapacitySettings {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Capacity thresholds
  lowCapacityHoursThreshold Int   @default(8)   // Hours below which capacity is "low"
  overallocationThreshold   Float @default(1.0) // 100% = overallocated
  minCapacityForCoverage    Int   @default(8)   // Min hours for coverage viability
  issueWindowDays           Int   @default(7)   // Days forward for issue detection

  // Capacity v1: Graduated thresholds
  severeOverloadThresholdPct Float @default(1.4) // 140% = severe overload
  underutilizedThresholdPct  Float @default(0.6) // 60% = underutilized
  defaultWeeklyHoursTarget   Int   @default(40)  // Default for quick-entry

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("org_capacity_settings")
}

model TeamCapacityPlan {
  id                String   @id @default(cuid())
  workspaceId       String
  teamId            String   @unique
  weeklyDemandHours Float    @default(0)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team      OrgTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("team_capacity_plans")
}

model OrgUiPreference {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  key         String
  valueJson   Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId, key])
  @@index([workspaceId])
  @@index([userId])
  @@map("org_ui_preferences")
}

model OrgHealthSnapshot {
  id         String   @id @default(cuid())
  orgId      String
  capturedAt DateTime @default(now())

  capacityScore    Float?
  ownershipScore   Float?
  balanceScore     Float?
  managementScore  Float?
  dataQualityScore Float?
  phaseCVersion    String?

  createdAt DateTime @default(now())

  @@index([orgId, capturedAt])
  @@map("org_health_snapshots")
}

model OrgHealthSignal {
  id    String @id @default(cuid())
  orgId String

  // Stable identity for dedupe + lifecycle
  signalKey String

  type        OrgHealthSignalType
  severity    OrgHealthSeverity
  title       String
  description String

  contextType  String?
  contextId    String?
  contextLabel String?
  href         String?

  // Phase 5: Structured metadata for LoopBrain reasoning
  // Contains signal-specific context (e.g. directReportCount, affectedSkills, etc.)
  signalMetadata Json?

  // Phase 5: Change detection
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  dismissedAt DateTime?

  @@index([orgId, type])
  @@index([orgId, signalKey])
  @@index([orgId, severity])
  @@index([orgId, firstSeenAt])
  @@map("org_health_signals")
}

enum OrgHealthSignalType {
  // Existing signal types
  CAPACITY
  OWNERSHIP
  STRUCTURE
  MANAGEMENT_LOAD
  DATA_QUALITY

  // Phase 5: Extended intelligence signal types
  MANAGEMENT_OVERLOAD // Manager has >8 direct reports
  MANAGEMENT_UNDERLOAD // Manager has <2 direct reports
  SINGLE_POINT_FAILURE // Team has 1 person with critical skill
  OWNERSHIP_GAP // Entity has no owner
  COVERAGE_GAP // No backup for critical role
  AVAILABILITY_CRUNCH // >50% of team unavailable
  SKILL_GAP // Required skill not present on team
  STALE_DATA // Availability data older than threshold
  ORPHAN_POSITION // Position with no person assigned
  CYCLE_DETECTED // Circular reporting chain
}

enum OrgHealthSeverity {
  INFO
  WARNING
  CRITICAL
}

model OrgFixEvent {
  id          String   @id @default(cuid())
  orgId       String
  personId    String?
  fixType     String // e.g. ASSIGN_MANAGER, ASSIGN_TEAM, ASSIGN_ROLE
  beforeState Json
  afterState  Json
  impactScore Int
  createdAt   DateTime @default(now())

  @@index([orgId, createdAt])
  @@map("org_fix_events")
}

model SavedOrgView {
  id          String   @id @default(cuid())
  orgId       String
  key         String // e.g. "leadership_structure"
  title       String
  description String?
  persona     String // EXECUTIVE | HR | MANAGER
  config      Json // filters, sort, issueTypes, layout hints
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orgId, key])
  @@index([orgId, persona])
  @@map("saved_org_views")
}

model OrgDefaultView {
  id        String   @id @default(cuid())
  orgId     String
  role      String // EXECUTIVE | HR | MANAGER | MEMBER
  viewKey   String // SavedOrgView.key
  createdAt DateTime @default(now())

  @@unique([orgId, role])
  @@map("org_default_views")
}

model OrgHealthDigest {
  id         String    @id @default(cuid())
  orgId      String
  cadence    String // WEEKLY
  lastSentAt DateTime?
  enabled    Boolean   @default(true)
  recipients Json // array of { role, userId? }
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([orgId])
  @@map("org_health_digests")
}

model AuditLogEntry {
  id          String   @id @default(cuid())
  orgId       String
  actorUserId String?
  actorLabel  String // fallback display name if user not resolvable
  action      String
  targetCount Int
  summary     String
  createdAt   DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("audit_log_entries")
}

model OrgMembership {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole  @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId, role])
  @@map("org_memberships")
}

model PersonAvailability {
  id          String           @id @default(cuid())
  workspaceId String // Workspace scoping (Phase 1: schema truth)
  personId    String // References User.id (person in Org context)
  type        AvailabilityType
  startDate   DateTime
  endDate     DateTime?
  fraction    Float? // 0.0–1.0, used only for PARTIAL
  note        String?

  // Phase 2: Structured availability reason for LoopBrain reasoning
  reason             AvailabilityReason?
  expectedReturnDate DateTime? // When capacity is expected to return

  // Phase G: Source tracking for precedence rules (MANUAL > INTEGRATION)
  source      AvailabilitySource @default(MANUAL)
  createdById String? // User who created this record (audit trail)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person    User      @relation(fields: [personId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, personId])
  @@index([personId, startDate])
  @@index([workspaceId])
  @@index([workspaceId, reason])
  @@index([workspaceId, source])
  @@map("person_availability")
}

enum AvailabilityType {
  AVAILABLE // fully available (100% capacity)
  UNAVAILABLE // vacation, sick leave, parental leave
  PARTIAL // e.g. 50% capacity
}

// Phase 2: Structured reasons for absence/reduced availability
enum AvailabilityReason {
  VACATION
  SICK_LEAVE
  PARENTAL_LEAVE
  SABBATICAL
  JURY_DUTY
  BEREAVEMENT
  TRAINING
  OTHER
}

// Phase G: Source tracking for availability events
// MANUAL takes precedence over INTEGRATION when overlapping
enum AvailabilitySource {
  MANUAL // Entered by user or admin
  INTEGRATION // Synced from external system (calendar, HRIS)
}

model ProjectAllocation {
  id        String @id @default(cuid())
  orgId     String
  projectId String
  personId  String

  // fraction of a person's working capacity, e.g. 0.2 = 20%
  fraction Float

  startDate DateTime
  endDate   DateTime?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  person  User    @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([orgId, projectId])
  @@index([personId, startDate])
  @@map("project_allocations")
}

model Role {
  id          String   @id @default(cuid())
  orgId       String
  name        String // e.g. "Product Manager"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org              Org                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  responsibilities RoleResponsibility[]

  @@index([orgId])
  @@map("roles")
}

model RoleResponsibility {
  id        String              @id @default(cuid())
  roleId    String
  scope     ResponsibilityScope
  target    String // free-text, e.g. "Product roadmap", "Payments projects"
  createdAt DateTime            @default(now())

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([roleId])
  @@map("role_responsibilities")
}

enum ResponsibilityScope {
  OWNERSHIP // what this role can own
  DECISION // what this role can decide on
  EXECUTION // what this role is expected to work on
}

model PersonCapacity {
  id       String @id @default(cuid())
  orgId    String
  personId String

  // 1.0 = full-time; 0.5 = half-time
  fte Float @default(1.0)

  // 0..100 (e.g., 25 means 25% shrinkage: meetings, PTO, overhead)
  shrinkagePct Float @default(20.0)

  // Optional: when the capacity profile was last reviewed
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, personId])
  @@index([orgId, personId])
  @@map("person_capacity")
}

model CapacityAllocation {
  id       String @id @default(cuid())
  orgId    String
  personId String

  // Optional targets — keep flexible for now
  teamId    String?
  projectId String?

  // 0..100 (% of person's working time allocated)
  percent Float

  note String?

  startsAt DateTime?
  endsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, personId])
  @@index([orgId, teamId])
  @@index([orgId, projectId])
  @@map("capacity_allocations")
}

enum AvailabilityStatus {
  AVAILABLE
  LIMITED
  UNAVAILABLE
}

model PersonAvailabilityHealth {
  id          String @id @default(cuid())
  workspaceId String // Phase 1: migrated from orgId to workspaceId
  personId    String

  status AvailabilityStatus @default(AVAILABLE)
  // Optional: "PTO", "Sick", "Parental leave", "Meetings-heavy", etc.
  reason String?

  // Optional time window
  startsAt DateTime?
  endsAt   DateTime?

  // Phase 2: Expected return date for LoopBrain capacity planning
  expectedReturnDate DateTime?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, personId])
  @@index([workspaceId, personId])
  @@index([workspaceId, status])
  @@map("person_availability_health")
}

// ============================================================================
// Phase 3: Skills and Competencies
// ============================================================================

// Skill taxonomy - first-class skill entities for LoopBrain reasoning
model Skill {
  id          String  @id @default(cuid())
  workspaceId String
  name        String // e.g. "Python", "Product Management", "UI Design"
  category    String? // e.g. "Engineering", "Design", "Management"
  description String?

  // Skill relationships
  personSkills   PersonSkill[]
  roleCardSkills RoleCardSkill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([workspaceId, category])
  @@map("skills")
}

// Person-skill assignment with proficiency level
model PersonSkill {
  id          String @id @default(cuid())
  workspaceId String
  personId    String // References User.id
  skillId     String

  // Proficiency: 1 (beginner) to 5 (expert)
  proficiency Int @default(3)

  // Verification tracking
  verifiedAt   DateTime?
  verifiedById String? // User who verified this skill

  // Self-reported vs externally validated
  source SkillSource @default(SELF_REPORTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, personId, skillId])
  @@index([workspaceId, personId])
  @@index([workspaceId, skillId])
  @@index([skillId, proficiency])
  @@map("person_skills")
}

// Junction table for RoleCard skill requirements
model RoleCardSkill {
  id         String            @id @default(cuid())
  roleCardId String
  skillId    String
  type       RoleCardSkillType // REQUIRED or PREFERRED

  // Minimum proficiency level required (1-5)
  minProficiency Int @default(3)

  createdAt DateTime @default(now())

  roleCard RoleCard @relation(fields: [roleCardId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([roleCardId, skillId, type])
  @@index([roleCardId])
  @@index([skillId])
  @@index([type])
  @@map("role_card_skills")
}

enum SkillSource {
  SELF_REPORTED // Person added this skill themselves
  MANAGER_ADDED // Manager assigned this skill
  VERIFIED // Externally verified (e.g. certification)
  INFERRED // Derived from role/project history
}

enum RoleCardSkillType {
  REQUIRED // Must have this skill
  PREFERRED // Nice to have
}

model PersonRoleAssignment {
  id       String @id @default(cuid())
  orgId    String
  personId String

  // Flexible role labels for now (e.g., "Engineer", "PM", "Designer", "QA")
  role String

  // 0..100 share of role if multi-role
  percent Float @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, personId, role])
  @@index([orgId, personId])
  @@index([orgId, role])
  @@map("person_role_assignments")
}

enum OwnedEntityType {
  TEAM
  DEPARTMENT
  DOMAIN
  PROJECT
  SYSTEM
}

model OwnerAssignment {
  id          String @id @default(cuid())
  workspaceId String // Phase 1: migrated from orgId to workspaceId

  entityType  OwnedEntityType
  entityId    String
  entityLabel String?

  // Person responsible (or future: group)
  ownerPersonId String

  // Optional: distinguishes primary/secondary coverage later
  isPrimary Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, entityType, entityId]) // One owner per entity per workspace
  @@index([workspaceId, entityType])
  @@index([workspaceId, entityType, entityId])
  @@index([workspaceId, ownerPersonId])
  @@map("owner_assignments")
}

model Domain {
  id          String  @id @default(cuid())
  orgId       String
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, name])
  @@map("domains")
}

model SystemEntity {
  id          String  @id @default(cuid())
  orgId       String
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, name])
  @@map("system_entities")
}

model PersonManagerLink {
  id          String @id @default(cuid())
  workspaceId String // Phase 1: migrated from orgId to workspaceId
  personId    String
  managerId   String

  // Optional time window
  startsAt DateTime?
  endsAt   DateTime?

  // Phase 1: Intentional absence tracking for structural integrity
  // When true, LoopBrain will not flag this as MISSING_MANAGER
  intentionallyUnassigned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, personId, managerId])
  @@index([workspaceId, personId])
  @@index([workspaceId, managerId])
  @@map("person_manager_links")
}

model ManagerProfile {
  id       String @id @default(cuid())
  orgId    String
  personId String

  // Optional: "people manager" flag (vs IC)
  isManager Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, personId])
  @@map("manager_profiles")
}

model OrgRoleTaxonomy {
  id        String   @id @default(cuid())
  orgId     String
  label     String
  createdAt DateTime @default(now())

  @@unique([orgId, label])
  @@index([orgId])
  @@map("org_role_taxonomy")
}

model OrgSkillTaxonomy {
  id        String   @id @default(cuid())
  orgId     String
  label     String
  createdAt DateTime @default(now())

  @@unique([orgId, label])
  @@index([orgId])
  @@map("org_skill_taxonomy")
}

// ============================================================================
// Phase G: Capacity & Availability Foundation
// ============================================================================

/**
 * CapacityContract - Defines weekly capacity when fully available
 * Invariant: Only ONE active contract per person per date
 * If multiple contracts overlap → CAPACITY_CONTRACT_CONFLICT issue
 */
model CapacityContract {
  id                  String    @id @default(cuid())
  workspaceId         String
  personId            String // References User.id
  weeklyCapacityHours Float // e.g., 40, 32, 20
  effectiveFrom       DateTime
  effectiveTo         DateTime? // null = open-ended
  createdById         String? // User who created this contract
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, personId])
  @@index([personId, effectiveFrom])
  @@index([workspaceId, effectiveFrom])
  @@map("capacity_contracts")
}

/**
 * WorkAllocation - Committed work that consumes capacity
 * Invariant: allocationPercent is relative to contracted capacity (not raw hours)
 * Formula: allocatedHours = weeklyCapacityHours × allocationPercent
 * Stacking rule: Allocations are additive
 * Over-allocation (sum > 1.0) is allowed but flagged as OVERALLOCATED_PERSON
 */
model WorkAllocation {
  id                String                @id @default(cuid())
  workspaceId       String
  personId          String // References User.id
  allocationPercent Float // 0–1 (relative to contracted capacity)
  contextType       AllocationContextType
  contextId         String? // ID of team/project/role
  contextLabel      String? // Human-readable label
  startDate         DateTime
  endDate           DateTime? // null = open-ended
  source            AllocationSource      @default(MANUAL)
  createdById       String? // User who created this allocation
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, personId])
  @@index([personId, startDate])
  @@index([workspaceId, contextType])
  @@map("work_allocations")
}

// Context type for work allocations
enum AllocationContextType {
  TEAM
  PROJECT
  ROLE
  OTHER
}

// Source tracking for allocations (mirrors AvailabilitySource)
enum AllocationSource {
  MANUAL // Entered by user or admin
  INTEGRATION // Synced from external system
}

/**
 * RoleCoverage - Defines backup/secondary personnel for critical roles
 * Phase G6: Enables "who can cover if X is unavailable?" queries.
 * Minimal model - not a full skills engine.
 */
model RoleCoverage {
  id                 String   @id @default(cuid())
  workspaceId        String
  roleType           String // e.g., "TEAM_LEAD", "ON_CALL", "PROJECT_OWNER"
  roleLabel          String? // Human-readable label
  primaryPersonId    String // Primary person for this role
  secondaryPersonIds String[] // Backup personnel (ordered by priority)
  createdById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, roleType, primaryPersonId])
  @@index([workspaceId, roleType])
  @@index([workspaceId, primaryPersonId])
  @@map("role_coverage")
}

// ============================================================================
// Phase H: Work Intake Sizing + Role Requirement Foundation
// ============================================================================

enum WorkPriority {
  P0
  P1
  P2
  P3
}

enum EffortEstimateType {
  HOURS
  TSHIRT
}

enum TShirtSize {
  XS
  S
  M
  L
  XL
}

enum WorkDomainType {
  TEAM
  DEPARTMENT
  ROLE
  FUNCTION
  OTHER
}

enum WorkRequestStatus {
  OPEN
  CLOSED
}

enum SeniorityLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
  PRINCIPAL
}

model WorkRequest {
  id          String @id @default(cuid())
  workspaceId String

  title       String
  description String?

  priority     WorkPriority
  desiredStart DateTime
  desiredEnd   DateTime

  effortType   EffortEstimateType
  effortHours  Float? // Required if effortType = HOURS
  effortTShirt TShirtSize? // Required if effortType = TSHIRT

  domainType        WorkDomainType
  domainId          String? // teamId, departmentId, etc.
  requiredRoleType  String? // e.g., "Engineer", "PM"
  requiredSeniority SeniorityLevel?

  requesterPersonId String? // For traceability
  createdById       String

  // Phase I: Decision authority for escalation
  decisionDomainKey String? // e.g., "SECURITY", "HIRING"

  status   WorkRequestStatus @default(OPEN)
  closedAt DateTime?

  // O1: Intent-Driven Onboarding
  isProvisional Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Phase J: Impact relationships
  impacts WorkImpact[]

  // Phase K: Work responsibility tagging
  // Note: Inferred tags are NOT auto-persisted; only explicit tags stored
  workTags         ResponsibilityTag[] @relation("WorkTags")
  primaryWorkTagId String?             // Optional: single primary for UI simplicity

  // W1.5: Recommendation Closure
  recommendationLogs WorkRecommendationLog[]

  @@index([workspaceId, status])
  @@index([workspaceId, desiredStart])
  @@index([workspaceId, domainType, domainId])
  @@map("work_requests")
}

model WorkEffortDefaults {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  xsHours     Float    @default(4)
  sHours      Float    @default(8)
  mHours      Float    @default(16)
  lHours      Float    @default(32)
  xlHours     Float    @default(64)
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("work_effort_defaults")
}

// ============================================================================
// Phase I: Decision Authority Mapping
// ============================================================================

enum DecisionDomainScope {
  TEAM
  DEPARTMENT
  FUNCTION
  WORKSPACE
}

model DecisionDomain {
  id          String              @id @default(cuid())
  workspaceId String
  key         String              // e.g., "HIRING", "SECURITY"
  name        String              // Display name
  description String?
  scope       DecisionDomainScope @default(WORKSPACE)
  isArchived  Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  authority DecisionAuthority?

  @@unique([workspaceId, key])
  @@index([workspaceId, isArchived])
  @@map("decision_domains")
}

model DecisionAuthority {
  id              String   @id @default(cuid())
  domainId        String   @unique

  // Primary decider (one of these is set)
  primaryPersonId String?
  primaryRoleType String? // Resolved dynamically

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  domain          DecisionDomain           @relation(fields: [domainId], references: [id], onDelete: Cascade)
  escalationSteps DecisionEscalationStep[]

  @@map("decision_authorities")
}

model DecisionEscalationStep {
  id          String @id @default(cuid())
  authorityId String
  stepOrder   Int // 0, 1, 2... explicit ordering

  // One of these is set
  personId String?
  roleType String?

  authority DecisionAuthority @relation(fields: [authorityId], references: [id], onDelete: Cascade)

  @@unique([authorityId, stepOrder])
  @@index([authorityId])
  @@map("decision_escalation_steps")
}

// ============================================================================
// Phase J: Impact & Dependency Graph (Blast Radius)
// ============================================================================

enum ImpactSubjectType {
  TEAM
  DEPARTMENT
  PERSON
  ROLE
  DECISION_DOMAIN
  WORK_REQUEST
}

enum ImpactType {
  BLOCKED // This work cannot complete unless the subject acts/changes
  DEPENDENT // The subject's work/outcome depends on this work
  INFORM // Subject should be informed if this changes
  CONSULT // Subject should be consulted before changing this
}

enum ImpactSeverity {
  LOW
  MEDIUM
  HIGH
}

/**
 * WorkImpact - Explicit impact declarations linking WorkRequests to affected entities
 * 
 * Key design decisions:
 * - No subjectLabel stored (resolved at read time to prevent stale data)
 * - impactKey stored as column for deterministic uniqueness across subject identity types
 * - impactKey format: ${workRequestId}:${subjectType}:${subjectIdentity}:${impactType}
 */
model WorkImpact {
  id            String            @id @default(cuid())
  workspaceId   String
  workRequestId String

  // Stable key for uniqueness and reconciliation
  // Format: ${workRequestId}:${subjectType}:${subjectIdentity}:${impactType}
  // Computed on create via computeImpactKey() helper
  impactKey String

  subjectType ImpactSubjectType
  subjectId   String? // For TEAM, DEPARTMENT, PERSON, WORK_REQUEST
  roleType    String? // For ROLE subject type
  domainKey   String? // For DECISION_DOMAIN subject type

  impactType  ImpactType
  severity    ImpactSeverity
  explanation String

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workRequest WorkRequest @relation(fields: [workRequestId], references: [id], onDelete: Cascade)

  // impactKey is the primary uniqueness constraint (simplest, most deterministic)
  @@unique([workspaceId, impactKey])
  @@index([workspaceId, workRequestId])
  @@index([workspaceId, subjectType, subjectId])
  @@map("work_impacts")
}

// ============================================================================
// Phase K: Role Responsibilities Canon
// ============================================================================

/**
 * ResponsibilityTag - Workspace-scoped tags describing work types
 * 
 * Tags are curated (create/archive, never hard delete).
 * Keys are UPPERCASE_UNDERSCORE format, e.g., "ENGINEERING_BACKEND".
 */
model ResponsibilityTag {
  id          String   @id @default(cuid())
  workspaceId String
  key         String   // UPPERCASE_UNDERSCORE, e.g., "ENGINEERING_BACKEND"
  label       String   // Human-readable, e.g., "Backend Engineering"
  description String?
  category    String?  // Optional grouping: "ENGINEERING", "PRODUCT", "DESIGN"
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Inverse relations for role profiles
  roleProfilePrimary   RoleResponsibilityProfile[] @relation("PrimaryTags")
  roleProfileAllowed   RoleResponsibilityProfile[] @relation("AllowedTags")
  roleProfileForbidden RoleResponsibilityProfile[] @relation("ForbiddenTags")

  // Person overrides
  personOverrides PersonResponsibilityOverride[]

  // Work request tagging
  workRequests WorkRequest[] @relation("WorkTags")

  @@unique([workspaceId, key])
  @@index([workspaceId, isArchived])
  @@map("responsibility_tags")
}

/**
 * RoleResponsibilityProfile - Maps roleType to allowed/primary/forbidden tags
 * 
 * Hard invariant: One profile per roleType per workspace.
 */
model RoleResponsibilityProfile {
  id          String   @id @default(cuid())
  workspaceId String
  roleType    String   // e.g., "Engineer", "PM", "Designer"

  // Seniority constraints (optional)
  minSeniority SeniorityLevel?
  maxSeniority SeniorityLevel?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace     Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  primaryTags   ResponsibilityTag[] @relation("PrimaryTags")
  allowedTags   ResponsibilityTag[] @relation("AllowedTags")
  forbiddenTags ResponsibilityTag[] @relation("ForbiddenTags")

  @@unique([workspaceId, roleType])
  @@index([workspaceId])
  @@map("role_responsibility_profiles")
}

/**
 * PersonResponsibilityOverride - Additive person-level tag overrides
 * 
 * Critical invariant: Overrides do not bypass forbidden responsibilities.
 * If a person has an override for tag X, but their role profile forbids X,
 * the forbidden still takes precedence in alignment resolution.
 */
model PersonResponsibilityOverride {
  id          String    @id @default(cuid())
  workspaceId String
  personId    String
  tagId       String
  reason      String?   // Why this override exists
  expiresAt   DateTime? // Optional time-bound (v1.1 enhancement)
  createdById String
  createdAt   DateTime  @default(now())

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tag       ResponsibilityTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, personId, tagId])
  @@index([workspaceId, personId])
  @@map("person_responsibility_overrides")
}

// =============================================================================
// W1.5: Recommendation Closure
// =============================================================================

enum WorkRecommendationAction {
  PROCEED
  DELAY
  REASSIGN
  REQUEST_SUPPORT
}

/**
 * WorkRecommendationLog -- Append-only log of feasibility recommendations
 *
 * Records the recommendation action shown to the user and their acknowledgement.
 * "Latest recommendation" = row with greatest createdAt for a given workRequestId.
 * Acknowledging an older log must never mark newer ones as acknowledged.
 *
 * snapshotJson is diagnostic only (≤ 5 KB, flat primitives). No business logic
 * may read or branch on its contents.
 */
model WorkRecommendationLog {
  id            String   @id @default(cuid())
  workspaceId   String
  workRequestId String

  recommendationAction WorkRecommendationAction
  recommendationReason String?
  snapshotJson         Json?

  acknowledgedAt   DateTime?
  acknowledgedById String?

  createdAt DateTime @default(now())

  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workRequest    WorkRequest      @relation(fields: [workRequestId], references: [id], onDelete: Cascade)
  acknowledgedBy WorkspaceMember? @relation(fields: [acknowledgedById], references: [id])

  @@index([workspaceId, workRequestId, createdAt])
  @@map("work_recommendation_logs")
}
