model LoopbrainPendingAction {
  id            String   @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Action type and status
  type          String   // "time_off_approval", "task_assignment", "decision_request"
  status        String   @default("AWAITING_RESPONSE") // "AWAITING_RESPONSE", "COMPLETED", "EXPIRED"
  
  // Context about what action is being requested
  contextType   String   // "LeaveRequest", "Task", "Project", "WorkRequest"
  contextId     String   // ID of the related entity
  contextData   Json?    // Additional context (analysis, recommendations, etc.)
  
  // Slack tracking (for matching button clicks to actions)
  slackChannelId   String?
  slackMessageTs   String? // Slack message timestamp (unique thread ID)
  slackUserId      String? // Slack user ID who should respond
  
  // Internal tracking
  createdBy     String   // userId who triggered this action
  assignedTo    String   // userId who should respond
  
  expiresAt     DateTime // When this action expires
  completedAt   DateTime? // When action was completed
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([workspaceId, status])
  @@index([slackMessageTs])
  @@index([assignedTo, status])
  @@map("loopbrain_pending_actions")
}

