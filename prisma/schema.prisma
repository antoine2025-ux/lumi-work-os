// Todo enums
enum TodoStatus {
  OPEN
  DONE
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
}

enum TodoAnchorType {
  NONE
  PROJECT
  TASK
  PAGE
}

model Todo {
  id           String         @id @default(cuid())
  workspaceId  String
  title        String
  note         String?
  status       TodoStatus     @default(OPEN)
  dueAt        DateTime?
  priority     TodoPriority?
  createdById  String
  assignedToId String
  anchorType   TodoAnchorType @default(NONE)
  anchorId     String?
