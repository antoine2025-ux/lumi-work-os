/**
 * WorkRecommendationLog -- Append-only log of feasibility recommendations
 *
 * Records the recommendation action shown to the user and their acknowledgement.
 * "Latest recommendation" = row with greatest createdAt for a given workRequestId.
 * Acknowledging an older log must never mark newer ones as acknowledged.
 *
 * snapshotJson is diagnostic only (≤ 5 KB, flat primitives). No business logic
 * may read or branch on its contents.
 */
model WorkRecommendationLog {
  id            String   @id @default(cuid())
  workspaceId   String
  workRequestId String

  recommendationAction WorkRecommendationAction
  recommendationReason String?
  snapshotJson         Json?

  acknowledgedAt   DateTime?
  acknowledgedById String?

  createdAt DateTime @default(now())

  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workRequest    WorkRequest      @relation(fields: [workRequestId], references: [id], onDelete: Cascade)
  acknowledgedBy WorkspaceMember? @relation(fields: [acknowledgedById], references: [id])

  @@index([workspaceId, workRequestId, createdAt])
  @@map("work_recommendation_logs")
}

// =============================================================================
// Loopbrain: Proactive Insights
// =============================================================================

/**
 * ProactiveInsight - Autonomous intelligence recommendations
 *
 * Stores insights detected by Loopbrain's insight detector, including
 * capacity issues, deadline clusters, blocked work, coverage gaps, etc.
 *
 * Lifecycle:
 * - ACTIVE: Insight is current and actionable
 * - EXPIRED: Insight has passed its expiration date
 * - DISMISSED: User has dismissed the insight
 * - SUPERSEDED: A newer insight has replaced this one
 *
 * @see src/lib/loopbrain/contract/proactiveInsight.v0.ts
 */
model ProactiveInsight {
  id          String @id @default(cuid())
  workspaceId String

  // Core fields from contract
  trigger     String // InsightTriggerV0: THRESHOLD_BREACH, PATTERN_DETECTED, etc.
  category    String // InsightCategoryV0: CAPACITY, WORKLOAD, DEADLINE, etc.
  priority    String // InsightPriorityV0: CRITICAL, HIGH, MEDIUM, LOW, INFO
  title       String
  description String
  confidence  Float  // 0.0–1.0

  // Recommendations stored as JSON array
  recommendations Json // RecommendationV0[]

  // Evidence stored as JSON array
  evidence Json // InsightEvidenceV0[]

  // Affected entities stored as JSON array
  affectedEntities Json // AffectedEntityV0[]

  // Lifecycle
  status    String    @default("ACTIVE") // InsightStatusV0
  expiresAt DateTime?

  // Dismissal tracking
  dismissedAt     DateTime?
  dismissedBy     String?
  dismissalReason String? // DismissalReasonV0
  dismissalNote   String?

  // Supersession (newer insight replaces older)
  supersedesId String?

  // Metadata for extensibility
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, category])
  @@index([workspaceId, priority])
  @@index([workspaceId, expiresAt])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("proactive_insights")
}

