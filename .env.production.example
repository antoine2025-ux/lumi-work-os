# ============================================================
# Loopwell — Production Environment Variables
# ============================================================
# Copy this file to .env.production.local and fill in values.
# Never commit actual secrets. All values here are empty or
# illustrative placeholders only.
# ============================================================

## Database
# Description: Primary PostgreSQL connection string (pooled via PgBouncer for serverless)
# Required: yes
# Where to get it: Supabase → Project Settings → Database → Connection string → Transaction mode
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Description: Direct (non-pooled) connection — used by Prisma migrations and batch operations
# Required: yes
# Where to get it: Supabase → Project Settings → Database → Connection string → Session mode
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

## Authentication
# Description: Secret used to sign/verify NextAuth JWTs and session cookies
# Required: yes
# Where to get it: Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Description: Canonical URL of the deployed app — used by NextAuth for redirect URLs
# Required: yes
# Where to get it: Your Vercel deployment URL or custom domain (e.g. https://app.loopwell.io)
NEXTAUTH_URL=https://your-domain.com

# Description: Public app base URL — used for invite links, emails, and client-side routing
# Required: yes
# Where to get it: Same as NEXTAUTH_URL
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Description: Canonical app URL — secondary reference used in appUrl utility
# Required: no (falls back to NEXT_PUBLIC_APP_URL or VERCEL_URL)
# Where to get it: Same as NEXTAUTH_URL
APP_URL=https://your-domain.com

## AI Providers
# Description: OpenAI API key — used for embeddings (text-embedding-3-small) and GPT chat
# Required: yes
# Where to get it: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Description: Anthropic API key — used for Claude models in Loopbrain pipelines
# Required: yes (Loopbrain uses Claude as primary reasoning model)
# Where to get it: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Description: Google AI API key — used for Gemini model fallback in providers.ts
# Required: no
# Where to get it: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Description: Loopbrain primary LLM model ID override
# Required: no (defaults to claude-sonnet-4-6 in code)
# Where to get it: Pick from Anthropic model IDs (e.g. claude-opus-4-6, claude-sonnet-4-6)
LOOPBRAIN_MODEL=

# Description: Loopbrain org reasoning model — used for org intelligence queries
# Required: no (defaults set in src/lib/loopbrain/config.ts)
# Where to get it: Same as LOOPBRAIN_MODEL
LOOPBRAIN_ORG_MODEL=

# Description: Max tokens for Loopbrain org responses
# Required: no
# Where to get it: Set based on model limits and cost budget (e.g. 4096)
LOOPBRAIN_ORG_MAX_TOKENS=

# Description: Timeout in ms for Loopbrain org LLM calls
# Required: no
# Where to get it: Set in milliseconds (e.g. 30000)
LOOPBRAIN_ORG_TIMEOUT_MS=

# Description: Enable/disable Loopbrain org intelligence feature
# Required: no (defaults to enabled)
# Where to get it: Set to "true" or "false"
LOOPBRAIN_ORG_ENABLED=true

## Supabase (Storage + Realtime)
# Description: Supabase project public URL
# Required: yes (if using Supabase storage or realtime)
# Where to get it: Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co

# Description: Supabase anon/public key — safe to expose client-side
# Required: yes
# Where to get it: Supabase → Project Settings → API → Project API keys → anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Description: Supabase service role key — server-side only, has full DB access
# Required: yes (for admin operations)
# Where to get it: Supabase → Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...

## Integrations — Slack
# Description: Slack OAuth app client ID
# Required: no (only if Slack integration is enabled)
# Where to get it: api.slack.com/apps → Your App → OAuth & Permissions → Client ID
SLACK_CLIENT_ID=

# Description: Slack OAuth app client secret
# Required: no
# Where to get it: api.slack.com/apps → Your App → OAuth & Permissions → Client Secret
SLACK_CLIENT_SECRET=

# Description: Slack signing secret — used to verify incoming webhook payloads (HMAC-SHA256)
# Required: no (only if receiving Slack webhooks)
# Where to get it: api.slack.com/apps → Your App → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=

# Description: OAuth redirect URI registered in your Slack app
# Required: no
# Where to get it: Set to: https://your-domain.com/api/integrations/slack/callback
SLACK_REDIRECT_URI=https://your-domain.com/api/integrations/slack/callback

## Integrations — Google Calendar
# Description: Google OAuth client ID — used for Google Calendar integration
# Required: no
# Where to get it: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=

# Description: Google OAuth client secret
# Required: no
# Where to get it: Same location as GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=

## Infrastructure — Email (Resend)
# Description: Resend API key — used for transactional email (invites, notifications)
# Required: yes (invite system requires email)
# Where to get it: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Description: From address for transactional emails
# Required: yes
# Where to get it: Must be a verified sender domain in Resend (e.g. hello@loopwell.io)
EMAIL_FROM=hello@your-domain.com

# Description: Secondary from address reference used in some email templates
# Required: no (falls back to EMAIL_FROM)
# Where to get it: Same as EMAIL_FROM
MAIL_FROM=

## Infrastructure — Redis (Cache)
# Description: Redis connection URL — used for caching and rate limiting
# Required: no (app degrades gracefully without it)
# Where to get it: Upstash Redis → Create Database → REST URL or Redis URL
REDIS_URL=redis://default:[password]@[host]:6379

## Feature Flags
# Description: Enable/disable the AI assistant feature
# Required: no
# Where to get it: Set to "true" or "false"
NEXT_PUBLIC_ENABLE_ASSISTANT=true

# Description: Enable/disable Socket.io realtime connections
# Required: no (defaults to false for serverless)
# Where to get it: Set to "true" only if running a dedicated Socket.io server
NEXT_PUBLIC_ENABLE_SOCKET_IO=false

# Description: Enable org context nightly sync cron job
# Required: no
# Where to get it: Set to "true" to enable background org context indexing
ORG_CONTEXT_NIGHTLY_ENABLED=true

# Description: Cron expression for nightly org context sync
# Required: no
# Where to get it: Standard cron expression (e.g. "0 2 * * *" for 2am UTC)
ORG_CONTEXT_NIGHTLY_CRON=0 2 * * *

# Description: Workspace scoping middleware — should always be true in production
# Required: no (defaults to true)
# Where to get it: Leave as true unless debugging scoping issues
PRISMA_WORKSPACE_SCOPING_ENABLED=true

# Description: Enable verbose API error logging
# Required: no
# Where to get it: Set to "true" for debug logging, omit in production
API_VERBOSE_LOGGING=

## Internal / Cron Secrets
# Description: Secret for authenticating internal Loopbrain cron endpoints
# Required: yes (used by Vercel Cron to call /api/internal/loopbrain/run)
# Where to get it: Generate with: openssl rand -hex 32
CRON_SECRET=

# Description: Secondary cron secret used by Loopbrain run endpoint
# Required: yes
# Where to get it: Generate with: openssl rand -hex 32 (can match CRON_SECRET)
LOOPBRAIN_CRON_SECRET=

# Description: Secret for blog admin login
# Required: no (only if using built-in blog admin)
# Where to get it: Generate a strong password
BLOG_ADMIN_PASSWORD=

## Mailchimp (Marketing, optional)
# Description: Mailchimp API key — used for mailing list on landing page
# Required: no
# Where to get it: Mailchimp → Account → Extras → API keys
MAILCHIMP_API_KEY=

# Description: Mailchimp audience/list ID
# Required: no
# Where to get it: Mailchimp → Audience → Manage Audience → Settings → Audience ID
MAILCHIMP_LIST_ID=
