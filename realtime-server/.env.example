# Railway provides PORT automatically
PORT=3000

# Same Supabase/Postgres connection string as the main app
# Hocuspocus needs this for wiki document load/store
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Shared secret between Vercel API routes and this server
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMIT_SECRET=change-me-to-a-random-secret

# Comma-separated allowed CORS origins (your Vercel domains)
ALLOWED_ORIGINS=http://localhost:3000,https://dev.loopwell.io,https://loopwell.io

NODE_ENV=production
