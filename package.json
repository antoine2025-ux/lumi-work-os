{
  "name": "loopwell",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORT=3000 next dev",
    "dev:turbo": "next dev --turbo",
    "dev:realtime": "tsx server.js",
    "dev:collab": "./scripts/free-port-auto.sh 1234 && tsx scripts/start-collab-server.ts",
    "dev:clear-cache": "rm -rf .next && echo '✅ Cleared .next build cache'",
    "dev:free-port": "./scripts/free-port-auto.sh 3000",
    "dev:free-port:all": "./scripts/free-port-auto.sh 3000 && ./scripts/free-port-auto.sh 3001 && ./scripts/free-port-auto.sh 3002",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "db:push": "prisma db push --skip-generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:push": "prisma db push --accept-data-loss --skip-generate",
    "db:seed": "prisma db seed",
    "db:seed:org-mock": "ORG_SEED_MODE=loopwell prisma db seed",
    "db:seed:loopwell": "node prisma/seed-loopwell-mock.js",
    "db:seed:loopwell:ws": "node prisma/seed-loopwell-mock.js",
    "db:seed:org": "tsx prisma/seed/org-seed.ts",
    "db:seed:acme": "SEED_ACME=true tsx prisma/seed.ts",
    "db:seed:acme:fresh": "SEED_ACME=true SEED_CLEAR_ACME=true tsx prisma/seed.ts",
    "start": "NODE_ENV=production tsx server.js",
    "start:e2e": "npm run build && next start -p 3000",
    "lint": "eslint",
    "seed": "ts-node prisma/seed.ts",
    "seed:dev": "tsx scripts/seed-dev.ts",
    "seed:e2e": "tsx scripts/seed-e2e-user.ts",
    "test:auth": "ts-node scripts/test-auth.ts",
    "backfill:spaces": "tsx scripts/backfill-canonical-spaces.ts",
    "fix:orphaned-projects": "tsx scripts/fix-orphaned-projects.ts",
    "migrate:backfill-org-positions": "tsx scripts/migrations/backfill-missing-org-positions.ts",
    "migrate:project-spaces": "tsx src/scripts/migrate-project-spaces.ts",
    "audit:project-org-scope": "tsx scripts/audit-project-org-scope.ts",
    "diagnostic:project-org": "tsx scripts/diagnostic/check-project-org-links.ts",
    "diagnostic:workspace-org-sync": "tsx scripts/diagnostic/check-workspace-org-sync.ts",
    "print-db": "npx tsx scripts/print-db.ts",
    "verify-db": "./scripts/verify-db-match.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --config=playwright.config.no-server.ts",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "perf:lighthouse": "lhci autorun",
    "security:deps": "npm audit --audit-level=high || (echo '⚠️ High/critical vulnerabilities found - see above. Run: npm audit fix' && exit 1)",
    "security:secrets": "./scripts/scan-secrets.sh",
    "security:semgrep": "semgrep --config=semgrep.yml src/",
    "check:org-prisma-any": "./scripts/check-org-prisma-any.sh",
    "check:org-prisma-any:update": "./scripts/check-org-prisma-any.sh --update-baseline",
    "quality:gate": "npm run test:e2e && npm run security:deps && npm run security:secrets",
    "quality:gate:strict": "npm run typecheck && npm run lint && npm run test && npm run test:e2e && npm run security:deps && npm run security:secrets && npm run security:semgrep",
    "health:check": "node health-check.js",
    "phase2:check": "./scripts/phase2-safety-check.sh",
    "phase2:staging-test": "./scripts/phase2-staging-test.sh",
    "phase3:verify": "./scripts/phase3-production-verify.sh",
    "phase3:deploy": "npm run build && npm start && npm run phase3:verify",
    "smoke:invites:dev": "ts-node scripts/dev-smoke-invite-link.ts",
    "test:loopbrain:snap:update": "vitest run src/lib/loopbrain/__tests__/loopbrain.snapshots.test.ts -u",
    "org:scan": "node scripts/org-scan.js",
    "org:inventory": "node scripts/org-inventory.js",
    "org:guard": "node scripts/org-guard.js",
    "org:context:doc-guard": "node scripts/org-context-doc-guard.js",
    "org:loopbrain:contract": "node scripts/org-loopbrain-contract.js",
    "org:loopbrain:contract:v2": "node scripts/org-loopbrain-contract-v2.js",
    "org:smoke": "node scripts/org-smoke.js",
    "org:onboarding:flow": "node scripts/org-onboarding-flow.js",
    "org:mvp:pressure-test": "tsx scripts/org-mvp-pressure-test.ts",
    "org:mvp:smoke": "tsx scripts/org-mvp-pressure-test.ts --mode=smoke",
    "org:mvp:help": "tsx scripts/org-cookie-print-help.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
