    "framer-motion": "^12.23.23",
    "googleapis": "^164.1.0",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.0.0",
    "lowlight": "^2.9.0",
    "lucide-react": "^0.544.0",
    "marked": "^16.3.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "openai": "^6.1.0",
    "pg": "^8.16.3",
    "pgvector": "^0.2.1",
    "prisma": "^6.16.3",
    "react": "19.1.0",
    "react-d3-tree": "^3.6.6",
